{
  "character_id": "ali_teacher_v1",
  "voice_references": [
    {
      "id": "neutral_01",
      "file": "assets/voice/ali_ref_neutral_01.wav",
      "transcript": "Hello everyone. Today we are going to learn how to choose the right robot by understanding robot characteristics and manipulator types.",
      "style": "clear_teacher",
      "duration_target_sec": 12
    },
    {
      "id": "neutral_02",
      "file": "assets/voice/ali_ref_neutral_02.wav",
      "transcript": "When you read a robot datasheet, you should immediately think about payload, reach, workspace, repeatability, and the real task requirements.",
      "style": "clear_teacher",
      "duration_target_sec": 12
    },
    {
      "id": "serious_01",
      "file": "assets/voice/ali_ref_serious_01.wav",
      "transcript": "Accuracy and repeatability are not the same thing, and confusing them can lead to the wrong robot choice.",
      "style": "serious_clear",
      "duration_target_sec": 10
    },
    {
      "id": "compare_01",
      "file": "assets/voice/ali_ref_compare_01.wav",
      "transcript": "Reach is the maximum distance from the base, while workspace is the total region where the end effector can actually operate.",
      "style": "compare_explain",
      "duration_target_sec": 11
    },
    {
      "id": "demo_01",
      "file": "assets/voice/ali_ref_demo_01.wav",
      "transcript": "Now let us compare the motion of a six-axis articulated robot with the simpler motion of other manipulator types.",
      "style": "energetic_demo",
      "duration_target_sec": 10
    },
    {
      "id": "recap_01",
      "file": "assets/voice/ali_ref_recap_01.wav",
      "transcript": "If you remember the main tradeoffs between stiffness, speed, workspace, and flexibility, you can make much better robot selections.",
      "style": "calm_recap",
      "duration_target_sec": 12
    }
  ],
