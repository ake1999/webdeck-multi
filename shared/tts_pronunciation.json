{
  "schema_version": "tts-pronunciation-v1",
  "description": "Spoken-only replacements for TTS. On-screen text, subtitles, and segment.text stay unchanged. Arian (Persian آرین) is spoken Ahreean (no hyphens; dashes stretch flite/Qwen).",
  "phrase_replacements": [
    {
      "match": "Arian University",
      "speak": "Ahreean University",
      "word_boundary": true,
      "ignore_case": true,
      "note": "Persian آرین — Ahreean, one smooth word"
    },
    {
      "match": "Arian",
      "speak": "Ahreean",
      "word_boundary": true,
      "ignore_case": true,
      "note": "Persian given name آرین"
    }
  ],
  "short_forms": [
    { "match": "lim", "speak": "limit", "word_boundary": true, "ignore_case": true },
    { "match": "sqrt", "speak": "square root", "word_boundary": true, "ignore_case": true },
    { "match": "sin", "speak": "sine", "word_boundary": true, "ignore_case": true },
    { "match": "cos", "speak": "cosine", "word_boundary": true, "ignore_case": true },
    { "match": "tan", "speak": "tangent", "word_boundary": true, "ignore_case": true }
  ]
}